---
import "~/styles/global.css";
import { generateDashboardSnapshot } from "~/lib/mock-data";
import { dashboardSvg, LAYOUT } from "~/lib/svg";

const snapshot = generateDashboardSnapshot();
const pageSize = 10;
const svgContent = dashboardSvg(snapshot, pageSize);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Call Center Dashboard</title>
  </head>
  <body class="bg-surface-alt text-text-primary min-h-screen" data-ws-url="/ws">
    <header class="bg-surface border-b border-border px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <h1 class="text-xl font-semibold tracking-tight">Call Center Dashboard</h1>
        <div class="flex items-center gap-2 text-sm text-text-secondary">
          <span id="connection-status" class="inline-flex items-center gap-1.5">
            <span data-status-dot class="w-2 h-2 rounded-full bg-status-offline"></span>
            <span data-status-label>Connecting…</span>
          </span>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-6">
      <svg
        id="dashboard-svg"
        viewBox={`0 0 ${LAYOUT.width} ${LAYOUT.height}`}
        width="100%"
        preserveAspectRatio="xMidYMin meet"
        role="img"
        aria-label="Call center dashboard showing KPI metrics and agent status"
        style="font-family: inherit;"
      >
        <title>Call Center Dashboard</title>
        <desc>Real-time call center metrics and agent status table</desc>
        <Fragment set:html={svgContent} />
      </svg>
    </main>

    <script type="application/json" id="initial-data" set:html={JSON.stringify(snapshot)} />
    <script src="~/client/index.ts"></script>
  </body>
</html>
