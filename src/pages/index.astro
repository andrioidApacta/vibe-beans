---
import "~/styles/global.css";
import { generateDashboardSnapshot } from "~/lib/mock-data";
import { statusDotSvg, statusLabels } from "~/lib/svg";
import { formatTime } from "~/lib/format";

const snapshot = generateDashboardSnapshot();
const pageSize = 10;
const initialAgents = snapshot.agents.slice(0, pageSize);
const totalPages = Math.ceil(snapshot.agents.length / pageSize);
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Callcenter Dashboard</title>
  </head>
  <body class="bg-surface-alt text-text-primary min-h-screen" data-ws-url="/ws">
    <header class="bg-surface border-b border-border px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <h1 class="text-xl font-semibold tracking-tight">Callcenter Dashboard</h1>
        <div class="flex items-center gap-2 text-sm text-text-secondary">
          <span id="connection-status" class="inline-flex items-center gap-1.5">
            <span data-status-dot class="w-2 h-2 rounded-full bg-status-offline"></span>
            <span data-status-label>Forbinder…</span>
          </span>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-6 space-y-6">
      <section aria-label="Nøgletal">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          <div class="bg-surface rounded-xl border border-border p-4">
            <p class="text-xs font-medium text-text-secondary uppercase tracking-wide">Opkald i alt</p>
            <p class="text-2xl font-bold mt-1" data-kpi="totalCallsToday">{snapshot.kpi.totalCallsToday}</p>
          </div>
          <div class="bg-surface rounded-xl border border-border p-4">
            <p class="text-xs font-medium text-text-secondary uppercase tracking-wide">Gns. behandlingstid</p>
            <p class="text-2xl font-bold mt-1" data-kpi="avgHandleTimeSeconds">{formatTime(snapshot.kpi.avgHandleTimeSeconds)}</p>
          </div>
          <div class="bg-surface rounded-xl border border-border p-4">
            <p class="text-xs font-medium text-text-secondary uppercase tracking-wide">Gns. ventetid</p>
            <p class="text-2xl font-bold mt-1" data-kpi="avgWaitTimeSeconds">{formatTime(snapshot.kpi.avgWaitTimeSeconds)}</p>
          </div>
          <div class="bg-surface rounded-xl border border-border p-4">
            <p class="text-xs font-medium text-text-secondary uppercase tracking-wide">Serviceniveau</p>
            <p class="text-2xl font-bold mt-1" data-kpi="serviceLevelPercent">{snapshot.kpi.serviceLevelPercent}%</p>
          </div>
          <div class="bg-surface rounded-xl border border-border p-4">
            <p class="text-xs font-medium text-text-secondary uppercase tracking-wide">Opkald i kø</p>
            <p class="text-2xl font-bold mt-1" data-kpi="callsInQueue">{snapshot.kpi.callsInQueue}</p>
          </div>
          <div class="bg-surface rounded-xl border border-border p-4">
            <p class="text-xs font-medium text-text-secondary uppercase tracking-wide">Opgivelsesrate</p>
            <p class="text-2xl font-bold mt-1" data-kpi="abandonRatePercent">{snapshot.kpi.abandonRatePercent}%</p>
          </div>
        </div>
      </section>

      <section aria-label="Agentstatus" class="bg-surface rounded-xl border border-border">
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
          <h2 class="text-base font-semibold">Agentstatus</h2>
          <span id="page-indicator" class="text-sm text-text-secondary">
            Side 1 af {totalPages}
          </span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-sm" aria-label="Agentstatus tabel">
            <thead>
              <tr class="border-b border-border text-left text-text-secondary">
                <th class="px-5 py-3 font-medium">Agent</th>
                <th class="px-5 py-3 font-medium">Status</th>
                <th class="px-5 py-3 font-medium text-right">Opkald i dag</th>
                <th class="px-5 py-3 font-medium text-right">Gns. behandlingstid</th>
              </tr>
            </thead>
            <tbody id="agent-tbody">
              {initialAgents.map((agent) => (
                <tr class="border-b border-border last:border-b-0 hover:bg-surface-alt transition-colors" data-agent-id={agent.id}>
                  <td class="px-5 py-3 font-medium">{agent.name}</td>
                  <td class="px-5 py-3">
                    <span class="inline-flex items-center gap-2">
                      <Fragment set:html={statusDotSvg(agent.status)} />
                      {statusLabels[agent.status]}
                    </span>
                  </td>
                  <td class="px-5 py-3 text-right tabular-nums">{agent.callsToday}</td>
                  <td class="px-5 py-3 text-right tabular-nums">{formatTime(agent.handleTimeSeconds)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="px-5 py-3 border-t border-border flex items-center justify-between text-sm text-text-secondary">
          <span id="agent-count">{snapshot.agents.length} agenter i alt</span>
          <div class="flex gap-1" id="page-dots">
            {Array.from({ length: totalPages }, (_, i) => (
              <button
                class={`w-2 h-2 rounded-full transition-colors ${i === 0 ? "bg-accent" : "bg-border"}`}
                data-page={i}
                aria-label={`Gå til side ${i + 1}`}
              />
            ))}
          </div>
        </div>
      </section>
    </main>

    <script type="application/json" id="initial-data" set:html={JSON.stringify(snapshot)} />
    <script src="~/client/index.ts"></script>
  </body>
</html>
